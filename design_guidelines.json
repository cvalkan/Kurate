{
  "project_name": "PaperSumo Badges",
  "version": "1.0",
  "design_philosophy": {
    "core_identity": "Scientific Prestige meets Modern Fintech",
    "vibe": "Exclusive, Data-Rich, Dark Mode, High Contrast",
    "anti_patterns": [
      "Generic certificate scrollwork",
      "Gradients that look like WordArt",
      "Low contrast text",
      "Cluttered academic citation formats"
    ]
  },
  "typography": {
    "font_family": "Liberation Sans",
    "weights": {
      "regular": "LiberationSans-Regular.ttf",
      "bold": "LiberationSans-Bold.ttf"
    },
    "hierarchy": {
      "rank_number": {
        "size": 180,
        "weight": "bold",
        "tracking": "tight",
        "description": "The visual anchor. Massive, unapologetic."
      },
      "tier_label": {
        "size": 36,
        "weight": "bold",
        "case": "uppercase",
        "tracking": "wide (2px)"
      },
      "title": {
        "size": 48,
        "weight": "bold",
        "leading": 60,
        "description": "High readability, max 2 lines."
      },
      "authors": {
        "size": 32,
        "weight": "regular",
        "color": "muted"
      },
      "stats_value": {
        "size": 42,
        "weight": "bold",
        "description": "Monospaced feel via layout"
      },
      "stats_label": {
        "size": 20,
        "weight": "regular",
        "case": "uppercase",
        "color": "muted"
      },
      "brand": {
        "size": 24,
        "weight": "bold",
        "opacity": 0.8
      }
    }
  },
  "colors": {
    "theme": "Dark Luxury",
    "backgrounds": {
      "deep_obsidian": "#050505",
      "midnight_navy": "#0F172A",
      "rich_charcoal": "#18181B"
    },
    "text": {
      "primary": "#FFFFFF",
      "secondary": "#94A3B8",
      "tertiary": "#475569"
    },
    "tiers": {
      "gold": {
        "primary": "#FBBF24",
        "glow": "#78350F",
        "rgb": [251, 191, 36],
        "bg_accent": "#451a03"
      },
      "silver": {
        "primary": "#E2E8F0",
        "glow": "#475569",
        "rgb": [226, 232, 240],
        "bg_accent": "#1e293b"
      },
      "bronze": {
        "primary": "#D97706",
        "glow": "#7C2D12",
        "rgb": [217, 119, 6],
        "bg_accent": "#431407"
      }
    }
  },
  "concepts": [
    {
      "id": "concept_a",
      "name": "The Obsidian Slab (Recommended)",
      "description": "A vertical split layout. Left 25% is a solid colored sidebar (Tier Color) housing the Rank. Right 75% is deep obsidian showing the data. This creates a bold 'stop-scrolling' visual anchor.",
      "layout_logic": {
        "canvas": [1200, 630],
        "sidebar": {
          "width": 300,
          "color": "Tier Primary or Darkened Tier",
          "elements": [
            { "type": "text", "content": "#RANK", "align": "center", "y": "center_visual" },
            { "type": "text", "content": "TIER NAME", "align": "center", "y": "below_rank" }
          ]
        },
        "main_area": {
          "x_start": 360,
          "width": 780,
          "elements": [
            { "type": "text", "content": "CATEGORY • ARCHIVE", "y": 60, "style": "label_muted" },
            { "type": "text", "content": "TITLE", "y": 110, "max_lines": 2, "style": "heading_white" },
            { "type": "text", "content": "AUTHORS", "y": "below_title + 30", "style": "body_muted" },
            { "type": "grid", "y": 480, "columns": 4, "elements": ["ELO", "WIN RATE", "MATCHES", "PAPERS"] },
            { "type": "text", "content": "PaperSumo by Kurate.org", "y": 570, "align": "right", "style": "brand_logo" }
          ]
        }
      }
    },
    {
      "id": "concept_b",
      "name": "The Orbit",
      "description": "Centralized radial design. A glowing ring (Tier Color) in the center holds the rank. Data floats around it.",
      "layout_logic": {
        "canvas": [1200, 630],
        "background": "Radial Gradient (simulated via concentric circles)",
        "center_piece": {
          "x": 600,
          "y": 250,
          "radius": 120,
          "stroke": 4,
          "content": "#RANK"
        },
        "details": {
          "y_start": 420,
          "align": "center",
          "elements": ["TITLE", "AUTHORS", "STATS_ROW"]
        }
      }
    }
  ],
  "implementation_guidelines": {
    "backend_pillow": {
      "file_path": "/app/backend/routers/badges.py",
      "instructions": [
        "Replace the current simple drawing logic with Concept A (Obsidian Slab).",
        "Use 'Image.new' with 'RGB' and the background color (15, 23, 42).",
        "Draw a rectangle for the sidebar: [(0,0), (300, 630)]. Fill with Tier Dark Accent.",
        "Draw a massive vertical line or accent bar: [(295, 0), (300, 630)] fill with Tier Bright Color.",
        "Title Text Wrap: Write a helper function to wrap text at ~35 characters for font size 48.",
        "Stats Grid: Calculate X positions dynamically: x=360, x=560, x=760, x=960."
      ]
    },
    "frontend_react": {
      "file_path": "/app/frontend/src/pages/BadgePage.jsx",
      "instructions": [
        "Update the 'TIER_STYLES' to match the new 'Dark Luxury' palette.",
        "Change the 'badge-card' container to have a dark background (slate-950) instead of the current light styles.",
        "Use 'border-l-8' (left border) colored by Tier to mimic the image design.",
        "Ensure the 'Share' buttons are prominent and high-contrast."
      ]
    }
  },
  "asset_generation": {
    "icons": "Use Lucide React icons in frontend. No external assets for Pillow (draw geometric shapes).",
    "logo": "Render 'PaperSumo' as text in Pillow using the Bold font."
  }
}
